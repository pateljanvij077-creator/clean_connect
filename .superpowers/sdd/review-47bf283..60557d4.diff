+    .from('booking_verification_codes')
+    .select('*')
+    .eq('booking_id', bookingId)
+    .eq('code_type', codeType)
+    .eq('used', false)
+    .gt('expiry_time', new Date().toISOString())
+    .maybeSingle()
+
+  if (error) throw error
+  return data
+}
